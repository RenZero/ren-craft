---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 — Page Not Found">
  <main id="main-content" class="min-h-screen flex items-center justify-center px-6">
    <div class="text-center max-w-md">
      <div class="text-9xl font-black gradient-text mb-6" aria-hidden="true">404</div>
      <h1 class="text-3xl font-bold text-white mb-4">頁面不存在</h1>
      <p class="text-slate-400 mb-8 leading-relaxed">
        您訪問的頁面似乎已移動或不存在。<br />
        返回首頁繼續探索。
      </p>
      <a
        href="/"
        id="back-home-btn"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-brand-600 hover:bg-brand-500
               text-white font-semibold transition-all duration-300
               hover:shadow-xl hover:shadow-brand-600/30 hover:-translate-y-0.5"
      >
        ← 回到首頁
      </a>
    </div>
  </main>
</BaseLayout>
