---
const metrics = [
  { value: "13+",  unit: "年", label: "研發經驗",       icon: "⚡" },
  { value: "TB",   unit: "級", label: "時序資料吞吐量",  icon: "📊" },
  { value: "99.9", unit: "%",  label: "系統可用性",     icon: "🛡️" },
  { value: "80",   unit: "%",  label: "MLOps 成本降低", icon: "🤖" },
  { value: "40",   unit: "%",  label: "部署效率提升",   icon: "🚀" },
];
---

<section
  id="about"
  class="relative min-h-screen flex flex-col justify-center overflow-hidden pt-24"
  aria-label="Hero — Personal identity and core metrics"
>
  <!-- Background decorative blobs -->
  <div class="absolute inset-0 pointer-events-none overflow-hidden" aria-hidden="true">
    <div class="absolute -top-40 -right-40 w-96 h-96 rounded-full bg-brand-600/20 blur-3xl"></div>
    <div class="absolute top-1/2 -left-40 w-80 h-80 rounded-full bg-accent-500/10 blur-3xl"></div>
    <div class="absolute bottom-20 right-1/4 w-64 h-64 rounded-full bg-brand-800/30 blur-2xl"></div>
    <!-- Grid pattern -->
    <div
      class="absolute inset-0 opacity-[0.03]"
      style="background-image: linear-gradient(rgba(99,102,241,0.5) 1px, transparent 1px), linear-gradient(90deg, rgba(99,102,241,0.5) 1px, transparent 1px); background-size: 60px 60px;"
    ></div>
  </div>

  <div class="w-full relative z-10">
    <!-- Status badge -->
    <div class="flex justify-center mb-10 animate-fade-in-up" style="animation-delay: 0.1s; opacity: 0;">
      <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-accent-500/10 border border-accent-500/30 text-accent-400 text-sm font-medium">
        <span class="w-2 h-2 rounded-full bg-accent-400 animate-pulse"></span>
        Available for Senior / Lead positions
      </span>
    </div>

    <!-- Main headline — full-width centered -->
    <h1
      class="text-center font-black tracking-tight leading-[1.05] mb-8 animate-fade-in-up px-4"
      style="animation-delay: 0.2s; opacity: 0;"
    >
      <span class="block text-white text-6xl md:text-8xl lg:text-9xl">Ren Chen</span>
      <span class="block gradient-text text-4xl md:text-6xl lg:text-7xl mt-3 whitespace-nowrap">
        Tech Lead &amp; Software Architect
      </span>
    </h1>

    <!-- Sub headline — full-width centered -->
    <p
      class="text-center text-lg md:text-xl text-slate-400 px-6 max-w-3xl mx-auto leading-relaxed mb-12 animate-fade-in-up"
      style="animation-delay: 0.35s; opacity: 0;"
    >
      13+ 年後端與系統架構開發經驗，專精
      <strong class="text-slate-200">微服務設計</strong>、
      <strong class="text-slate-200">大規模資料處理</strong> 與
      <strong class="text-slate-200">DevOps 基礎建設</strong>，
      致力於打造高可用、可擴展的企業級系統。
    </p>

    <!-- CTA Buttons — centered -->
    <div
      class="flex flex-wrap justify-center gap-4 mb-20 animate-fade-in-up"
      style="animation-delay: 0.5s; opacity: 0;"
    >
      <a
        href="/experience"
        id="hero-cta-primary"
        class="inline-flex items-center gap-2 px-7 py-3.5 rounded-xl bg-brand-600 hover:bg-brand-500
               text-white font-semibold transition-all duration-300
               hover:shadow-xl hover:shadow-brand-600/30 hover:-translate-y-0.5"
      >
        查看完整履歷
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <polyline points="9 18 15 12 9 6"/>
        </svg>
      </a>
      <a
        href="/contact"
        id="hero-cta-secondary"
        class="inline-flex items-center gap-2 px-7 py-3.5 rounded-xl border border-white/10
               text-slate-300 hover:text-white hover:border-brand-400/50 font-semibold
               transition-all duration-300 hover:-translate-y-0.5 hover:bg-white/5"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
          <polyline points="22,6 12,13 2,6"/>
        </svg>
        聯絡我
      </a>
    </div>

    <!-- Metrics Banner — full-width grid -->
    <div
      class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-4 px-6 max-w-5xl mx-auto animate-fade-in-up"
      style="animation-delay: 0.65s; opacity: 0;"
      role="region"
      aria-label="Quantified achievements"
    >
      {metrics.map((m) => (
        <div class="glass-card p-5 text-center group">
          <div class="text-2xl mb-2" aria-hidden="true">{m.icon}</div>
          <div class="text-3xl font-black text-white leading-none">
            {m.value}<span class="text-brand-400 text-2xl">{m.unit}</span>
          </div>
          <div class="text-slate-500 text-xs mt-2 font-medium">{m.label}</div>
        </div>
      ))}
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce opacity-30" aria-hidden="true">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <polyline points="6 9 12 15 18 9"/>
    </svg>
  </div>
</section>
