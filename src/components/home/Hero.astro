---
const metrics = [
  { value: "13+",  unit: "年", label: "研發經驗",       icon: "⚡" },
  { value: "TB",   unit: "級", label: "時序資料吞吐量",  icon: "📊" },
  { value: "99.9", unit: "%",  label: "系統可用性",     icon: "🛡️" },
  { value: "80",   unit: "%",  label: "MLOps 成本降低", icon: "🤖" },
  { value: "40",   unit: "%",  label: "部署效率提升",   icon: "🚀" },
];
---

<section
  id="about"
  class="relative min-h-screen flex flex-col justify-center overflow-hidden pt-24 border-b-[3px] border-neo-black bg-neo-bg"
  aria-label="Hero — Personal identity and core metrics"
>
  <!-- Background grid pattern -->
  <div class="absolute inset-0 pointer-events-none overflow-hidden" aria-hidden="true">
    <div
      class="absolute inset-0 opacity-[0.1]"
      style="background-image: linear-gradient(#111 2px, transparent 2px), linear-gradient(90deg, #111 2px, transparent 2px); background-size: 60px 60px;"
    ></div>
  </div>

  <div class="w-full relative z-10 py-12">
    <!-- Status badge -->
    <div class="flex justify-center mb-10">
      <span class="inline-flex items-center gap-2 px-4 py-2 bg-neo-success border-[3px] border-neo-black text-neo-black text-sm font-bold shadow-[4px_4px_0px_0px_#111]">
        <span class="w-2 h-2 bg-neo-black border border-neo-black animate-pulse"></span>
        Available for Senior / Lead positions
      </span>
    </div>

    <!-- Profile Photo -->
    <div class="flex justify-center mb-8">
      <div class="w-32 h-32 md:w-40 md:h-40 rounded-full border-[4px] border-neo-black shadow-[8px_8px_0px_0px_#111] overflow-hidden bg-neo-primary">
        <img src="/images/RenChen.jpg" alt="Ren Chen Photo" class="w-full h-full object-cover" />
      </div>
    </div>

    <!-- Main headline — full-width centered -->
    <h1
      class="text-center font-black tracking-tight leading-[1.05] mb-8 px-4"
    >
      <span class="block text-neo-black text-6xl md:text-8xl lg:text-9xl uppercase">Ren Chen</span>
      <span class="inline-block bg-neo-secondary border-[4px] border-neo-black text-neo-black px-6 py-2 mt-6 text-3xl md:text-5xl lg:text-6xl whitespace-nowrap shadow-[8px_8px_0px_0px_#111] transform -rotate-1">
        Tech Lead &amp; Software Architect
      </span>
    </h1>

    <!-- Sub headline — full-width centered -->
    <p
      class="text-center text-lg md:text-xl text-neo-black font-bold px-6 max-w-3xl mx-auto leading-relaxed mb-12 bg-neo-white border-[4px] border-neo-black p-6 shadow-[6px_6px_0px_0px_#111] transform rotate-1"
    >
      13+ 年後端與系統架構開發經驗，專精
      <strong class="bg-neo-primary px-1 border-[2px] border-neo-black">微服務設計</strong>、
      <strong class="bg-neo-accent px-1 border-[2px] border-neo-black">大規模資料處理</strong> 與
      <strong class="bg-neo-success px-1 border-[2px] border-neo-black">DevOps 基礎建設</strong>，
      致力於打造高可用、可擴展的企業級系統。
    </p>

    <!-- CTA Buttons — centered -->
    <div
      class="flex flex-wrap justify-center gap-6 mb-20"
    >
      <a
        href="/experience"
        id="hero-cta-primary"
        class="neo-btn text-lg py-4 px-8 bg-neo-primary"
      >
        查看完整履歷
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="ml-2">
          <polyline points="9 18 15 12 9 6"/>
        </svg>
      </a>
      <a
        href="/contact"
        id="hero-cta-secondary"
        class="neo-btn text-lg py-4 px-8 bg-neo-white"
      >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="mr-2">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
          <polyline points="22,6 12,13 2,6"/>
        </svg>
        聯絡我
      </a>
    </div>

    <!-- Metrics Banner — full-width grid -->
    <div
      class="grid grid-cols-2 md:grid-cols-5 gap-6 px-6 max-w-5xl mx-auto"
      role="region"
      aria-label="Quantified achievements"
    >
      {metrics.map((m) => (
        <div class="neo-card p-6 text-center flex flex-col justify-center bg-neo-white">
          <div class="text-4xl mb-3" aria-hidden="true">{m.icon}</div>
          <div class="text-4xl font-black text-neo-black leading-none">
            {m.value}<span class="text-xl ml-1">{m.unit}</span>
          </div>
          <div class="text-neo-black text-sm mt-3 font-bold uppercase">{m.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>

