---
const linkedinUrl = "https://www.linkedin.com/in/chen-hou-jen-990b62116/";
---

<footer class="border-t-[4px] border-neo-black bg-neo-primary py-12 mt-20">
  <div class="container mx-auto px-6">
    <div class="flex flex-col md:flex-row items-center justify-between gap-8">
      <!-- Left: Brand -->
      <div class="text-center md:text-left">
        <p class="font-black text-neo-black text-2xl uppercase">Ren Chen <span class="bg-neo-white px-2 py-1 border-[2px] border-neo-black text-sm ml-2 relative -top-1">/厚任</span></p>
        <p class="text-neo-black font-bold text-sm mt-3 uppercase">Tech Lead · Software Architect · 13+ Years</p>
      </div>

      <!-- Center: Quick links -->
      <nav aria-label="Footer navigation">
        <ul class="flex flex-wrap justify-center gap-4 list-none">
          {[
            { href: "/experience", label: "工作經歷" },
            { href: "/skills",     label: "技能專長" },
            { href: "/contact",    label: "聯絡我"   },
          ].map(link => (
            <li>
              <a href={link.href} class="text-neo-black font-black hover:bg-neo-white hover:border-neo-black border-[3px] border-transparent px-3 py-1 transition-colors text-sm uppercase">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- Right: Social Links -->
      <div class="flex items-center gap-4">
        <a
          href="mailto:a19850728@gmail.com"
          id="footer-email-link"
          class="text-neo-black bg-neo-white border-[3px] border-neo-black p-2 hover:bg-neo-secondary hover:shadow-[2px_2px_0px_0px_#111] transition-all transform hover:-translate-y-1"
          aria-label="Email Ren Chen"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
            <polyline points="22,6 12,13 2,6"/>
          </svg>
        </a>
        <a
          href={linkedinUrl}
          id="footer-linkedin-link"
          target="_blank"
          rel="noopener noreferrer"
          class="text-neo-black bg-neo-white border-[3px] border-neo-black p-2 hover:bg-neo-accent hover:shadow-[2px_2px_0px_0px_#111] transition-all transform hover:-translate-y-1"
          aria-label="Ren Chen on LinkedIn"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
            <rect x="2" y="9" width="4" height="12"/>
            <circle cx="4" cy="4" r="2"/>
          </svg>
        </a>
        <a
          href="https://github.com/renchen"
          id="footer-github-link"
          target="_blank"
          rel="noopener noreferrer"
          class="text-neo-black bg-neo-white border-[3px] border-neo-black p-2 hover:bg-neo-success hover:shadow-[2px_2px_0px_0px_#111] transition-all transform hover:-translate-y-1"
          aria-label="Ren Chen on GitHub"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>
          </svg>
        </a>
      </div>
    </div>

    <p class="text-center text-neo-black font-bold text-xs mt-12 border-t-[3px] border-neo-black/20 pt-8 uppercase">
      © {new Date().getFullYear()} Ren Chen. Built with Astro · TypeScript · Tailwind CSS
    </p>
  </div>
</footer>
