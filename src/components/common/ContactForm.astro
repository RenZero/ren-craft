---
const linkedinUrl = "https://www.linkedin.com/in/chen-hou-jen-990b62116/";
---

<section
  id="contact"
  class="section bg-neo-bg"
  aria-label="Contact Ren Chen"
>
  <div class="container mx-auto px-6">
    <div class="max-w-2xl mx-auto">
      <!-- Section header -->
      <div class="text-center mb-12">
        <div class="inline-block bg-neo-success border-[3px] border-neo-black px-4 py-2 mb-6 shadow-[4px_4px_0px_0px_#111] transform rotate-2">
          <p class="text-neo-black text-sm font-black tracking-widest uppercase">Get In Touch</p>
        </div>
        <h2 class="text-4xl md:text-6xl font-black text-neo-black uppercase">聯絡我</h2>
        <p class="text-neo-black font-bold mt-6 leading-relaxed bg-neo-white border-[3px] border-neo-black p-4 shadow-[4px_4px_0px_0px_#111]">
          無論是技術合作、架構諮詢或 Senior / Lead 職位邀約，歡迎直接寫信給我。
        </p>
      </div>

      <!-- Quick contact links -->
      <div class="grid grid-cols-2 gap-6 mb-10">
        <a
          href="mailto:a19850728@gmail.com"
          id="contact-email-link"
          class="neo-card p-5 flex flex-col md:flex-row items-center gap-4 group hover:no-underline text-center md:text-left bg-neo-primary"
          aria-label="Email Ren Chen at a19850728@gmail.com"
        >
          <div class="w-12 h-12 border-[3px] border-neo-black bg-neo-white flex items-center justify-center text-neo-black shrink-0 shadow-[2px_2px_0px_0px_#111]">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
              <polyline points="22,6 12,13 2,6"/>
            </svg>
          </div>
          <div>
            <p class="text-xs text-neo-black font-black uppercase">Email</p>
            <p class="text-sm text-neo-black font-bold mt-0.5">a19850728@gmail.com</p>
          </div>
        </a>

        <a
          href={linkedinUrl}
          id="contact-linkedin-link"
          target="_blank"
          rel="noopener noreferrer"
          class="neo-card p-5 flex flex-col md:flex-row items-center gap-4 group hover:no-underline text-center md:text-left bg-neo-accent"
          aria-label="Connect with Ren Chen on LinkedIn"
        >
          <div class="w-12 h-12 border-[3px] border-neo-black bg-neo-white flex items-center justify-center text-neo-black shrink-0 shadow-[2px_2px_0px_0px_#111]">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
              <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
              <rect x="2" y="9" width="4" height="12"/>
              <circle cx="4" cy="4" r="2"/>
            </svg>
          </div>
          <div>
            <p class="text-xs text-neo-black font-black uppercase">LinkedIn</p>
            <p class="text-sm text-neo-black font-bold mt-0.5">Ren Chen (厚任)</p>
          </div>
        </a>
      </div>

      <!-- Contact Form -->
      <form
        id="contact-form"
        class="neo-card p-8 flex flex-col gap-6 bg-neo-white"
        novalidate
        aria-label="Contact form"
      >
        <div class="grid sm:grid-cols-2 gap-6">
          <div>
            <label for="contact-name" class="block text-sm font-black text-neo-black mb-2 uppercase">姓名 *</label>
            <input
              type="text"
              id="contact-name"
              name="name"
              required
              autocomplete="name"
              placeholder="Your Name"
              class="w-full px-4 py-3 bg-neo-white border-[3px] border-neo-black
                     text-neo-black font-bold placeholder:text-neo-black/50 text-sm
                     focus:outline-none focus:shadow-[4px_4px_0px_0px_#111]
                     transition-all duration-200 shadow-[2px_2px_0px_0px_#111]"
            />
          </div>
          <div>
            <label for="contact-email" class="block text-sm font-black text-neo-black mb-2 uppercase">Email *</label>
            <input
              type="email"
              id="contact-email"
              name="email"
              required
              autocomplete="email"
              placeholder="your@email.com"
              class="w-full px-4 py-3 bg-neo-white border-[3px] border-neo-black
                     text-neo-black font-bold placeholder:text-neo-black/50 text-sm
                     focus:outline-none focus:shadow-[4px_4px_0px_0px_#111]
                     transition-all duration-200 shadow-[2px_2px_0px_0px_#111]"
            />
          </div>
        </div>

        <div>
          <label for="contact-subject" class="block text-sm font-black text-neo-black mb-2 uppercase">主旨</label>
          <input
            type="text"
            id="contact-subject"
            name="subject"
            placeholder="合作邀約 / 技術諮詢 / Job Offer"
            class="w-full px-4 py-3 bg-neo-white border-[3px] border-neo-black
                   text-neo-black font-bold placeholder:text-neo-black/50 text-sm
                   focus:outline-none focus:shadow-[4px_4px_0px_0px_#111]
                   transition-all duration-200 shadow-[2px_2px_0px_0px_#111]"
          />
        </div>

        <div>
          <label for="contact-message" class="block text-sm font-black text-neo-black mb-2 uppercase">訊息 *</label>
          <textarea
            id="contact-message"
            name="message"
            required
            rows="5"
            placeholder="請描述您的需求或機會..."
            class="w-full px-4 py-3 bg-neo-white border-[3px] border-neo-black
                   text-neo-black font-bold placeholder:text-neo-black/50 text-sm resize-none
                   focus:outline-none focus:shadow-[4px_4px_0px_0px_#111]
                   transition-all duration-200 shadow-[2px_2px_0px_0px_#111]"
          ></textarea>
        </div>

        <button
          type="submit"
          id="contact-submit-btn"
          class="neo-btn w-full text-lg py-4 mt-2 bg-neo-secondary"
        >
          送出訊息
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="ml-2">
            <polyline points="9 18 15 12 9 6"/>
          </svg>
        </button>

        <p id="contact-form-status" class="text-center text-neo-black font-bold text-sm hidden p-3 border-[3px] border-neo-black shadow-[2px_2px_0px_0px_#111]" aria-live="polite"></p>
      </form>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const status = document.getElementById('contact-form-status');
  const submitBtn = document.getElementById('contact-submit-btn') as HTMLButtonElement | null;

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    if (!form || !status || !submitBtn) return;

    // 簡單驗證
    const name    = (form.querySelector('#contact-name')    as HTMLInputElement)?.value.trim();
    const email   = (form.querySelector('#contact-email')   as HTMLInputElement)?.value.trim();
    const message = (form.querySelector('#contact-message') as HTMLTextAreaElement)?.value.trim();
    const subject = (form.querySelector('#contact-subject') as HTMLInputElement)?.value.trim() || '官網聯絡詢問';

    if (!name || !email || !message) {
      status.classList.remove('hidden', 'bg-neo-success');
      status.classList.add('bg-neo-secondary');
      status.textContent = '❌ 請填寫姓名、Email 與訊息欄位。';
      return;
    }

    // 組成 mailto: URL，開啟預設郵件客戶端
    const body = `姓名：${name}\nEmail：${email}\n\n${message}`;
    const mailtoURL = `mailto:a19850728@gmail.com`
      + `?subject=${encodeURIComponent(subject)}`
      + `&body=${encodeURIComponent(body)}`;

    window.location.href = mailtoURL;

    status.classList.remove('hidden', 'bg-neo-secondary');
    status.classList.add('bg-neo-success');
    status.textContent = '✅ 正在開啟郵件客戶端，請在信件中確認後送出。';
  });
</script>
