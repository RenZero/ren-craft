---
const linkedinUrl = "https://www.linkedin.com/in/chen-hou-jen-990b62116/";
---

<section
  id="contact"
  class="section"
  aria-label="Contact Ren Chen"
>
  <div class="container mx-auto px-6">
    <div class="max-w-2xl mx-auto">
      <!-- Section header -->
      <div class="text-center mb-12">
        <p class="text-brand-400 text-sm font-semibold tracking-widest uppercase mb-3">Get In Touch</p>
        <h2 class="text-4xl md:text-5xl font-bold text-white">聯絡我</h2>
        <p class="text-slate-400 mt-4 leading-relaxed">
          無論是技術合作、架構諮詢或 Senior / Lead 職位邀約，歡迎直接寫信給我。
        </p>
      </div>

      <!-- Quick contact links -->
      <div class="grid grid-cols-2 gap-4 mb-10">
        <a
          href="mailto:a19850728@gmail.com"
          id="contact-email-link"
          class="glass-card p-5 flex items-center gap-4 group hover:no-underline"
          aria-label="Email Ren Chen at a19850728@gmail.com"
        >
          <div class="w-10 h-10 rounded-xl bg-brand-600/20 flex items-center justify-center text-brand-400 group-hover:bg-brand-600/40 transition-colors shrink-0">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
              <polyline points="22,6 12,13 2,6"/>
            </svg>
          </div>
          <div>
            <p class="text-xs text-slate-500 font-medium">Email</p>
            <p class="text-sm text-white font-semibold mt-0.5">a19850728@gmail.com</p>
          </div>
        </a>

        <a
          href={linkedinUrl}
          id="contact-linkedin-link"
          target="_blank"
          rel="noopener noreferrer"
          class="glass-card p-5 flex items-center gap-4 group hover:no-underline"
          aria-label="Connect with Ren Chen on LinkedIn"
        >
          <div class="w-10 h-10 rounded-xl bg-sky-600/20 flex items-center justify-center text-sky-400 group-hover:bg-sky-600/40 transition-colors shrink-0">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
              <rect x="2" y="9" width="4" height="12"/>
              <circle cx="4" cy="4" r="2"/>
            </svg>
          </div>
          <div>
            <p class="text-xs text-slate-500 font-medium">LinkedIn</p>
            <p class="text-sm text-white font-semibold mt-0.5">Ren Chen (厚任)</p>
          </div>
        </a>
      </div>

      <!-- Contact Form -->
      <form
        id="contact-form"
        class="glass-card p-8 flex flex-col gap-5"
        novalidate
        aria-label="Contact form"
      >
        <div class="grid sm:grid-cols-2 gap-5">
          <div>
            <label for="contact-name" class="block text-sm font-medium text-slate-300 mb-2">姓名 *</label>
            <input
              type="text"
              id="contact-name"
              name="name"
              required
              autocomplete="name"
              placeholder="Your Name"
              class="w-full px-4 py-3 rounded-lg bg-white/5 border border-white/10
                     text-white placeholder:text-slate-600 text-sm
                     focus:outline-none focus:border-brand-400/60 focus:bg-white/8
                     transition-all duration-200"
            />
          </div>
          <div>
            <label for="contact-email" class="block text-sm font-medium text-slate-300 mb-2">Email *</label>
            <input
              type="email"
              id="contact-email"
              name="email"
              required
              autocomplete="email"
              placeholder="your@email.com"
              class="w-full px-4 py-3 rounded-lg bg-white/5 border border-white/10
                     text-white placeholder:text-slate-600 text-sm
                     focus:outline-none focus:border-brand-400/60 focus:bg-white/8
                     transition-all duration-200"
            />
          </div>
        </div>

        <div>
          <label for="contact-subject" class="block text-sm font-medium text-slate-300 mb-2">主旨</label>
          <input
            type="text"
            id="contact-subject"
            name="subject"
            placeholder="合作邀約 / 技術諮詢 / Job Offer"
            class="w-full px-4 py-3 rounded-lg bg-white/5 border border-white/10
                   text-white placeholder:text-slate-600 text-sm
                   focus:outline-none focus:border-brand-400/60
                   transition-all duration-200"
          />
        </div>

        <div>
          <label for="contact-message" class="block text-sm font-medium text-slate-300 mb-2">訊息 *</label>
          <textarea
            id="contact-message"
            name="message"
            required
            rows="5"
            placeholder="請描述您的需求或機會..."
            class="w-full px-4 py-3 rounded-lg bg-white/5 border border-white/10
                   text-white placeholder:text-slate-600 text-sm resize-none
                   focus:outline-none focus:border-brand-400/60
                   transition-all duration-200"
          ></textarea>
        </div>

        <button
          type="submit"
          id="contact-submit-btn"
          class="w-full py-3.5 rounded-xl bg-brand-600 hover:bg-brand-500
                 text-white font-semibold text-sm
                 transition-all duration-300
                 hover:shadow-xl hover:shadow-brand-600/30 hover:-translate-y-0.5
                 focus:outline-none focus:ring-2 focus:ring-brand-400/50"
        >
          送出訊息 →
        </button>

        <p id="contact-form-status" class="text-center text-sm hidden" aria-live="polite"></p>
      </form>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const status = document.getElementById('contact-form-status');
  const submitBtn = document.getElementById('contact-submit-btn') as HTMLButtonElement | null;

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    if (!form || !status || !submitBtn) return;

    // 簡單驗證
    const name    = (form.querySelector('#contact-name')    as HTMLInputElement)?.value.trim();
    const email   = (form.querySelector('#contact-email')   as HTMLInputElement)?.value.trim();
    const message = (form.querySelector('#contact-message') as HTMLTextAreaElement)?.value.trim();
    const subject = (form.querySelector('#contact-subject') as HTMLInputElement)?.value.trim() || '官網聯絡詢問';

    if (!name || !email || !message) {
      status.classList.remove('hidden', 'text-accent-400');
      status.classList.add('text-red-400');
      status.textContent = '❌ 請填寫姓名、Email 與訊息欄位。';
      return;
    }

    // 組成 mailto: URL，開啟預設郵件客戶端
    const body = `姓名：${name}\nEmail：${email}\n\n${message}`;
    const mailtoURL = `mailto:a19850728@gmail.com`
      + `?subject=${encodeURIComponent(subject)}`
      + `&body=${encodeURIComponent(body)}`;

    window.location.href = mailtoURL;

    status.classList.remove('hidden', 'text-red-400');
    status.classList.add('text-accent-400');
    status.textContent = '✅ 正在開啟郵件客戶端，請在信件中確認後送出。';
  });
</script>
