---
import { readdirSync, existsSync } from 'fs';
import { join } from 'path';
import PhotoCard from './PhotoCard.astro';

// 自動讀取 public/photos/ 內的所有圖片（build time）
const photosDir = join(process.cwd(), 'public', 'photos');
let photoFiles: string[] = [];
try {
  if (existsSync(photosDir)) {
    photoFiles = readdirSync(photosDir)
      .filter(f => /\.(jpg|jpeg|png|webp|avif|gif)$/i.test(f))
      .sort();
  }
} catch {
  photoFiles = [];
}

// 將檔名轉為易讀標題
function filenameToTitle(filename: string): string {
  return filename
    .replace(/\.[^.]+$/, '')        // 移除副檔名
    .replace(/[-_]/g, ' ')          // 底線/連字號換成空格
    .replace(/\b\w/g, c => c.toUpperCase()); // 首字母大寫
}
---

<section
  id="photography"
  class="section bg-neo-bg"
  aria-label="Photography gallery by Ren Chen"
>
  <div class="container mx-auto px-6">
    <!-- Section header -->
    <div class="text-center mb-16">
      <div class="inline-block bg-neo-secondary border-[3px] border-neo-black px-4 py-2 mb-6 shadow-[4px_4px_0px_0px_#111] transform -rotate-1">
        <p class="text-neo-black text-sm font-black tracking-widest uppercase">Visual Stories</p>
      </div>
      <h2 class="text-4xl md:text-6xl font-black text-neo-black uppercase">攝影藝廊</h2>
      <p class="text-neo-black font-bold mt-6 max-w-xl mx-auto bg-neo-white border-[3px] border-neo-black p-4 shadow-[4px_4px_0px_0px_#111]">
        用 Canon 5DMarkIII 記錄當下的光影——工程師視角下的另一種系統思維。
      </p>
      {photoFiles.length === 0 && (
        <p class="inline-block mt-6 text-sm font-bold text-neo-black border-[2px] border-neo-black bg-neo-primary px-4 py-2 shadow-[2px_2px_0px_0px_#111]">
          將照片放入 <code class="bg-neo-white px-1">public/photos/</code> 即可自動顯示
        </p>
      )}
    </div>

    {photoFiles.length > 0 ? (
      <!-- Masonry Grid：CSS Columns 輕量瀑布流 -->
      <div class="masonry-grid" role="list" aria-label="Photography gallery">
        {photoFiles.map((filename) => (
          <div role="listitem" class="masonry-item">
            <PhotoCard
              src={`/photos/${filename}`}
              alt={`Canon 5DMarkIII Photography by Ren Chen — ${filenameToTitle(filename)}`}
              title={filenameToTitle(filename)}
            />
          </div>
        ))}
      </div>
    ) : (
      <!-- Empty state -->
      <div class="flex flex-col items-center justify-center py-20 text-center neo-card bg-neo-white mx-auto max-w-md">
        <div class="text-6xl mb-6 bg-neo-accent border-[3px] border-neo-black w-24 h-24 flex items-center justify-center shadow-[4px_4px_0px_0px_#111] transform rotate-3" aria-hidden="true">📷</div>
        <h3 class="text-2xl font-black text-neo-black mb-3">尚無照片</h3>
        <p class="text-neo-black font-bold text-sm leading-relaxed border-[2px] border-neo-black p-3 bg-neo-bg">
          將 JPG / PNG / WebP 照片放入<br/>
          <code class="bg-neo-primary border-[2px] border-neo-black px-2 py-0.5 mt-2 inline-block">public/photos/</code><br/>
          重新 build 後即自動顯示
        </p>
      </div>
    )}
  </div>
</section>

<style>
  .masonry-grid {
    columns: 1;
    column-gap: 2rem;
  }
  @media (min-width: 768px)  { .masonry-grid { columns: 2; } }
  .masonry-item {
    break-inside: avoid;
    margin-bottom: 2rem;
  }
</style>
