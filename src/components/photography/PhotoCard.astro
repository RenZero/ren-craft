---
export interface Props {
  src: string;
  alt: string;
  title: string;
}

const { src, alt, title } = Astro.props;
---

<article
  class="photo-card relative group border-[4px] border-neo-black shadow-[8px_8px_0px_0px_#111] overflow-hidden bg-neo-white block transition-all duration-300 transform hover:-translate-y-2 hover:shadow-[12px_12px_0px_0px_#111]"
  aria-label={title}
>
  <img
    src={src}
    alt={alt}
    loading="lazy"
    decoding="async"
    class="w-full h-auto object-cover block border-b-[4px] border-neo-black grayscale-[20%] group-hover:grayscale-0 transition-all duration-300"
  />

  <div class="p-5 bg-neo-white">
    <p class="text-neo-black text-xl font-black uppercase tracking-wide">{title}</p>
  </div>
</article>
