---
export interface MetricBadge {
  label: string;
  value: string;
}

export interface Project {
  title: string;
  highlight: string;
  techStack: string[];
  metrics: MetricBadge[];
  difficulty?: number; // 可選，1-5
}

export interface Props {
  project: Project;
  index?: number;
}

const { project, index = 0 } = Astro.props;
---

<article
  id={`project-card-${index}`}
  class="neo-card p-6 flex flex-col gap-4 bg-neo-bg border-[3px] border-neo-black"
  aria-label={`Project: ${project.title}`}
>
  <!-- Title -->
  <h4 class="text-lg font-black text-neo-black leading-snug uppercase">{project.title}</h4>

  <!-- Highlight description -->
  <p class="text-neo-black font-bold text-sm leading-relaxed">{project.highlight}</p>

  <!-- Metrics Badges -->
  {project.metrics.length > 0 && (
    <div class="flex flex-wrap gap-2" role="list" aria-label="Project metrics">
      {project.metrics.map((m) => (
        <span
          role="listitem"
          class="inline-flex items-center gap-1.5 px-2 py-1 bg-neo-success border-[2px] border-neo-black text-neo-black text-xs font-black uppercase shadow-[2px_2px_0px_0px_#111]"
        >
          <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <polyline points="23 6 13.5 15.5 8.5 10.5 1 18" stroke="currentColor" stroke-width="3" fill="none"/>
            <polyline points="17 6 23 6 23 12" stroke="currentColor" stroke-width="3" fill="none"/>
          </svg>
          {m.label}:&nbsp;<strong class="text-neo-black">{m.value}</strong>
        </span>
      ))}
    </div>
  )}

  <!-- Tech Stack tags -->
  {project.techStack.length > 0 && (
    <div class="flex flex-wrap gap-2 pt-3 border-t-[3px] border-neo-black mt-2">
      {project.techStack.map((tag) => (
        <span class="px-2 py-1 text-xs font-black uppercase bg-neo-white border-[2px] border-neo-black text-neo-black">
          #{tag}
        </span>
      ))}
    </div>
  )}
</article>
